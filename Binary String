class Solution {
    public int binarySubstring(String s) {
        
        int onesCount = 0;
        int result = 0;

        // count total number of '1's
        for (int i = 0; i < s.length(); i++) {
            if (s.charAt(i) == '1') {
                onesCount++;
            }
        }

        // number of substrings that start and end with '1'
        result = (onesCount * (onesCount - 1)) / 2;

        return result;
    


    }
}
