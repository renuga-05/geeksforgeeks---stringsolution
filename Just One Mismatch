class Solution {
    static String isStringExist(String arr[], int N, String S) {
        for (int i = 0; i < N; i++) {
            
            String current = arr[i];
            
            // Step 1: Length must be same
            if (current.length() != S.length()) {
                continue;
            }
            
            int differenceCount = 0;
            
            // Step 2: Compare character by character
            for (int j = 0; j < S.length(); j++) {
                
                if (current.charAt(j) != S.charAt(j)) {
                    differenceCount++;
                }
                
                // Optimization: if more than 1 difference, stop checking
                if (differenceCount > 1) {
                    break;
                }
            }
            
            // Step 3: Check if exactly one character differs
            if (differenceCount == 1) {
                return "True";
            }
        }
        
        return "False";
        
    }
}
