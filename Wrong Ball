class Solution {
    public int countWrongPlacedBalls(String s) {
       int count = 0;

        for (int i = 0; i < s.length(); i++) {
            char ch = s.charAt(i);

            // R at odd index is wrong
            if (ch == 'R' && i % 2 != 0) {
                count++;
            }

            // B at even index is wrong
            if (ch == 'B' && i % 2 == 0) {
                count++;
            }
        }

        return count;  
    }
}
